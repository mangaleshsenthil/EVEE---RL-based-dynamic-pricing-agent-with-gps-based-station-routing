# ─────────────────────────────────────────────────────────────
# .gitignore — EVEE Dynamic Pricing Agent
# ─────────────────────────────────────────────────────────────

# ── Secrets & credentials (NEVER commit these) ────────────────
.streamlit/secrets.toml
secrets_docker.toml
secrets.toml
.env
*.pem
*.key
*.crt

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.egg
MANIFEST

# ── Virtual environments ──────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── Streamlit cache ───────────────────────────────────────────
.streamlit/cache/

# ── Docker ────────────────────────────────────────────────────
# Keep Dockerfile and docker-compose.yml but ignore local overrides
docker-compose.override.yml

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ── IDE ───────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.sublime-project
*.sublime-workspace

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Database ─────────────────────────────────────────────────
*.sqlite3
*.db

# ── Test artifacts ───────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml
